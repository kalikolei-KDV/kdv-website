# Prismic repository name (e.g. your-repo-name)
PRISMIC_ENVIRONMENT=

# Prismic access token. Only read at build time (react-router build's
# prerender step) — this site has no runtime server and no live preview.
PRISMIC_ACCESS_TOKEN=

# Prismic write access token, used for migrations/scripts, not by the app itself.
PRISMIC_WRITE_TOKEN=

# Production domain used to build absolute URLs in the generated sitemap.xml
# (scripts/generate-sitemap.mjs). Defaults to https://kingsmendv.com if unset.
SITE_URL=