{
  "format": "page",
  "id": "case_study",
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "client": {
        "type": "Text",
        "config": {
          "label": "Client",
          "placeholder": "e.g. Evolus — shown as the small label on the /work listing card"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": "Short display title — shown on the /work listing card. Separate from the case_study_header slice's own title so the listing page doesn't need to read into slice data."
        }
      },
      "listing_image": {
        "type": "Image",
        "config": {
          "label": "Listing image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "slices": {
        "config": {
          "choices": {
            "case_study_header": {
              "type": "SharedSlice"
            },
            "case_study_meta": {
              "type": "SharedSlice"
            },
            "two_column_copy": {
              "type": "SharedSlice"
            },
            "case_study_gallery": {
              "type": "SharedSlice"
            },
            "three_cards": {
              "type": "SharedSlice"
            },
            "titled_paragraph": {
              "type": "SharedSlice"
            },
            "case_study_results": {
              "type": "SharedSlice"
            },
            "case_study_feedback": {
              "type": "SharedSlice"
            }
          }
        },
        "fieldset": "Slice Zone",
        "type": "Slices"
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  },
  "label": "Case Study",
  "repeatable": true,
  "status": true
}
