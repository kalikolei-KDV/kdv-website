{
  "name": "kdv-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "node scripts/generate-sitemap.mjs && react-router build",
    "preview": "vite preview --outDir build/client",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen": "prismic-ts-codegen",
    "push-models": "node scripts/push-models.mjs",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-sitemap": "node scripts/generate-sitemap.mjs"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "dependencies": {
    "@prismicio/client": "^7.21.8",
    "@prismicio/react": "^3.4.1",
    "@tanstack/react-query": "^5.101.3",
    "isbot": "^5",
    "react": "^19.2.8",
    "react-dom": "^19.2.4",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/ibm-plex-mono": "^5.3.0",
    "@fontsource/instrument-sans": "^5.3.0",
    "@prismicio/custom-types-client": "^2.1.0",
    "@prismicio/mock": "^0.7.2",
    "@react-router/dev": "^8.2.0",
    "@tailwindcss/vite": "^4.3.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "prismic-ts-codegen": "^0.1.30",
    "tailwindcss": "^4.3.3",
    "typescript": "^5",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "volta": {
    "node": "22.22.0",
    "npm": "11.10.0"
  }
}
